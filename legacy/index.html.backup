<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Taiuo — AI-Powered Lifestyle & Skincare Intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* RESET */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Poppins', sans-serif; background: #fff; color: #2b3744; overflow-x: hidden; line-height: normal; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    ul { list-style: none; }

    /* TOKENS */
    :root {
      --navy:       #2b3744;
      --grey:       #6c7278;
      --lightblack: #1a1c1e;
      --red:        #ea2f3d;
      --red-h:      #ff4757;
      --bg:         #f5f6f9;
      --stroke:     #edf1f3;
      --white:      #ffffff;
      --slate:      #475569;
      --icon-bg:    #bfcff9;
      --green:      #2bbb73;
      --green-pale: #d1ffe8;
      --sh-sm:  0px 0px 35px rgba(0,0,0,0.05);
      --sh-md:  3px 6px 20.7px rgba(0,0,0,0.08);
      --r-sm:  8px;
      --r-md:  12px;
      --r-lg:  19px;
      --r-xl:  22px;
      --r-pill: 78px;
      --tr: 0.22s ease;
    }

    /* LAYOUT */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
    @media(max-width:600px){ .wrap { padding: 0 20px; } }
    .section    { padding: 96px 0; }
    .section-sm { padding: 64px 0; }

    /* TYPOGRAPHY */
    .eyebrow { font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--grey); margin-bottom: 14px; }
    h1 { font-size: clamp(2rem,4.5vw,3.2rem); font-weight: 600; line-height: 1.2; color: var(--lightblack); }
    h2 { font-size: clamp(1.6rem,3vw,2.2rem); font-weight: 600; line-height: 1.3; color: var(--navy); }
    .body-grey { font-size: 0.9375rem; color: var(--grey); line-height: 1.75; }
    .body-slate { font-size: 0.875rem; color: var(--slate); line-height: 1.75; letter-spacing: 0.2px; }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 8px; font-family: 'Poppins', sans-serif; font-size: 0.875rem; font-weight: 600; border-radius: var(--r-sm); padding: 13px 28px; transition: background var(--tr), transform var(--tr), box-shadow var(--tr); white-space: nowrap; cursor: pointer; }
    .btn-red { background: var(--red); color: var(--white); border: none; }
    .btn-red:hover { background: var(--red-h); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(234,47,61,0.28); }
    .btn-ghost { background: var(--bg); color: var(--navy); border: 1px solid var(--stroke); }
    .btn-ghost:hover { background: var(--stroke); }
    .pill-active { background: var(--navy); color: var(--white); padding: 10px 20px; border-radius: var(--r-pill); font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-block; transition: background var(--tr); }
    .pill-active:hover { background: #3d4f60; }
    .pill-inactive { background: var(--bg); color: var(--lightblack); padding: 10px 20px; border-radius: var(--r-pill); font-size: 14px; font-weight: 400; cursor: pointer; border: none; display: inline-block; transition: background var(--tr); }
    .pill-inactive:hover { background: #e5e7ea; }

    /* ICON CIRCLES */
    .icon-circle { width: 50px; height: 50px; border-radius: 50%; background: var(--icon-bg); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .icon-circle.green { background: var(--green-pale); }

    /* CARDS */
    .card { background: var(--white); border: 1px solid var(--stroke); border-radius: var(--r-lg); box-shadow: var(--sh-sm); transition: box-shadow var(--tr), transform var(--tr); }
    .card:hover { box-shadow: var(--sh-md); transform: translateY(-3px); }

    /* REVEAL */
    .rv { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .rv.up { opacity: 1; transform: none; }
    .d1{transition-delay:.08s} .d2{transition-delay:.16s} .d3{transition-delay:.24s} .d4{transition-delay:.32s}

    /* NAV */
    .nav { position: fixed; top:0; left:0; right:0; z-index:100; background: rgba(255,255,255,0.9); backdrop-filter: blur(5.5px); box-shadow: var(--sh-sm); border-bottom: 1px solid var(--stroke); }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; height: 68px; display: flex; align-items: center; gap: 32px; }
    .logo { display: flex; align-items: center; gap: 10px; font-size: 1.2rem; font-weight: 700; color: var(--navy); flex-shrink: 0; }
    .logo-mark { width: 34px; height: 34px; background: var(--navy); border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; color: var(--white); font-size: 15px; font-weight: 700; }
    .nav-links { display: flex; align-items: center; gap: 28px; flex: 1; }
    .nav-links a { font-size: 0.875rem; font-weight: 400; color: var(--grey); transition: color var(--tr); }
    .nav-links a:hover { color: var(--navy); }
    .nav-actions { display: flex; gap: 10px; margin-left: auto; flex-shrink: 0; }
    .ham { display: none; flex-direction: column; gap: 4px; cursor: pointer; margin-left: auto; }
    .ham span { display: block; width: 22px; height: 2px; background: var(--navy); border-radius: 2px; }
    @media(max-width:768px){ .nav-inner { padding: 0 20px; } .nav-links { display: none; } .ham { display: flex; } }
    .mob { display: none; position: fixed; inset:0; z-index:99; background: rgba(255,255,255,0.97); flex-direction: column; align-items: center; justify-content: center; gap: 32px; transform: translateY(-100%); transition: transform 0.35s ease; }
    .mob.on { display: flex; transform: translateY(0); }
    .mob a { font-size: 1.4rem; font-weight: 600; color: var(--navy); }
    .mob a:hover { color: var(--red); }
    .mob-x { position: absolute; top: 20px; right: 24px; font-size: 24px; color: var(--grey); cursor: pointer; }

    /* HERO */
    .hero { padding: 120px 0 0; background: var(--white); overflow: hidden; }
    .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; padding-bottom: 72px; }
    .hero h1 { margin-bottom: 18px; }
    .hero-sub { font-size: 1rem; color: var(--grey); line-height: 1.75; max-width: 460px; margin-bottom: 32px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
    .hero-trust { display: flex; align-items: center; gap: 14px; padding-top: 24px; border-top: 1px solid var(--stroke); }
    .avatars { display: flex; }
    .av { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--white); background: var(--icon-bg); margin-left: -8px; display: flex; align-items: center; justify-content: center; font-size: 13px; }
    .av:first-child { margin-left: 0; }
    .trust-t { font-size: 13px; color: var(--grey); }
    .trust-t strong { color: var(--navy); }
    .hero-vis { position: relative; display: flex; justify-content: center; }
    .app-card { background: var(--white); border: 1px solid var(--stroke); border-radius: var(--r-xl); box-shadow: 0 12px 40px rgba(0,0,0,0.1); width: 330px; overflow: hidden; animation: hf 5.5s ease-in-out infinite; }
    @keyframes hf { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    .app-bar { background: var(--navy); padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; }
    .app-bar-t { color: var(--white); font-size: 13px; font-weight: 600; }
    .app-dots { display: flex; gap: 5px; }
    .app-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.25); }
    .app-dot.on { background: var(--green); }
    .app-scan { background: var(--bg); margin: 14px; border-radius: var(--r-md); padding: 22px; text-align: center; border: 1.5px dashed var(--stroke); }
    .scan-face { width: 68px; height: 68px; border-radius: 50%; background: var(--icon-bg); margin: 0 auto 10px; display: flex; align-items: center; justify-content: center; font-size: 28px; position: relative; }
    .scan-ring { position: absolute; inset: -5px; border-radius: 50%; border: 2px solid var(--red); border-top-color: transparent; animation: sp 2s linear infinite; }
    @keyframes sp { to { transform: rotate(360deg); } }
    .scan-lbl { font-size: 10px; font-weight: 600; color: var(--red); letter-spacing: 1.5px; text-transform: uppercase; }
    .app-metrics { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; padding: 0 14px 14px; }
    .app-metric { background: var(--bg); border-radius: var(--r-md); padding: 10px 6px; text-align: center; border: 1px solid var(--stroke); }
    .metric-v { font-size: 14px; font-weight: 700; color: var(--navy); }
    .metric-v.g { color: var(--green); }
    .metric-v.r { color: var(--red); }
    .metric-l { font-size: 9px; color: var(--grey); margin-top: 2px; }
    .app-recs { padding: 0 14px 18px; }
    .recs-h { font-size: 10px; font-weight: 600; color: var(--grey); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
    .rec-item { display: flex; align-items: center; gap: 10px; background: var(--bg); border-radius: var(--r-md); padding: 9px 12px; margin-bottom: 7px; border: 1px solid var(--stroke); }
    .rec-ico { width: 30px; height: 30px; border-radius: var(--r-sm); background: var(--icon-bg); display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
    .rec-n { font-size: 11px; font-weight: 600; color: var(--navy); }
    .rec-m { font-size: 10px; color: var(--green); font-weight: 500; }
    .hbadge { position: absolute; background: var(--white); border: 1px solid var(--stroke); border-radius: var(--r-md); box-shadow: var(--sh-md); padding: 10px 14px; display: flex; align-items: center; gap: 10px; }
    .hbi { font-size: 18px; }
    .hbl { font-size: 9px; color: var(--grey); }
    .hbv { font-size: 12px; font-weight: 700; color: var(--navy); margin-top: 1px; }
    .ba { top: 16px; right: -12px; animation: bf1 6s ease-in-out infinite; }
    .bb { bottom: 56px; left: -20px; animation: bf2 8s ease-in-out infinite; }
    @keyframes bf1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
    @keyframes bf2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
    @media(max-width:900px){ .hero-grid { grid-template-columns: 1fr; } .hero-vis { display: none; } }

    /* STRIP */
    .strip { background: var(--navy); padding: 22px 0; overflow: hidden; }
    .strip-track { display: flex; gap: 52px; animation: st 22s linear infinite; width: max-content; }
    @keyframes st { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .strip-item { font-size: 13px; color: rgba(255,255,255,0.4); white-space: nowrap; display: flex; align-items: center; gap: 10px; }
    .strip-item::after { content:'·'; color: rgba(255,255,255,0.15); }

    /* STATS */
    .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--stroke); border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--sh-sm); }
    @media(max-width:768px){ .stats-grid { grid-template-columns: 1fr 1fr; } }
    .stat-cell { background: var(--white); padding: 40px 28px; transition: background var(--tr); }
    .stat-cell:hover { background: linear-gradient(135deg, #f8f9fc 0%, #f0f3ff 100%); }
    .stat-n { font-size: clamp(2rem,3.5vw,2.6rem); font-weight: 700; color: var(--navy); line-height: 1; margin-bottom: 8px; }
    .stat-d { font-size: 13px; color: var(--grey); line-height: 1.6; }

    /* FEATURES */
    .feat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 52px; }
    @media(max-width:900px){ .feat-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:600px){ .feat-grid { grid-template-columns: 1fr; } }
    .fc { padding: 32px 28px 36px; display: flex; flex-direction: column; gap: 16px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .fc:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
    .fc-icon-box { width: 80px; height: 80px; border-radius: 16px; background: linear-gradient(135deg, #e8ecff 0%, #f0f4ff 100%); display: flex; align-items: center; justify-content: center; margin-bottom: 8px; flex-shrink: 0; transition: background 0.3s ease, transform 0.3s ease; padding: 4px; }
    .fc:hover .fc-icon-box { background: linear-gradient(135deg, #d0d9ff 0%, #e0e7ff 100%); transform: scale(1.05); }
    .fc-icon-box img { width: 100%; height: 100%; object-fit: cover; border-radius: 12px; }
    .fc-featured .fc-icon-box { width: 100px; height: 100px; border-radius: 20px; background: linear-gradient(135deg, var(--navy) 0%, #3d4f60 100%); padding: 6px; }
    .fc-featured .fc-icon-box img { border-radius: 14px; }
    .fc-featured { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 40px; padding: 44px 48px; background: linear-gradient(135deg, #e8ecff 0%, #f5f8ff 50%, var(--white) 100%); position: relative; overflow: hidden; }
    .fc-featured::after { content: ''; position: absolute; top: -80px; right: -80px; width: 240px; height: 240px; border-radius: 50%; background: radial-gradient(circle, rgba(43,55,68,0.06) 0%, transparent 70%); pointer-events: none; }
    .fc-featured::before { content: ''; position: absolute; bottom: -60px; left: -60px; width: 200px; height: 200px; border-radius: 50%; background: radial-gradient(circle, rgba(102,126,234,0.08) 0%, transparent 70%); pointer-events: none; }
    @media(max-width:768px){ .fc-featured { grid-column: span 1; grid-template-columns: 1fr; } }
    .fc-content-wrap { display: flex; flex-direction: column; gap: 12px; }
    .fc-badge { background: var(--navy); border-radius: var(--r-lg); padding: 28px 32px; text-align: center; min-width: 140px; display: flex; flex-direction: column; gap: 6px; align-items: center; flex-shrink: 0; box-shadow: 0 8px 24px rgba(43,55,68,0.3); }
    .fc-badge-n { font-size: 2.2rem; font-weight: 700; color: var(--white); line-height: 1; }
    .fc-badge-l { font-size: 10px; color: rgba(255,255,255,0.55); font-weight: 500; letter-spacing: 0.5px; }
    .fc-title { font-size: 1.05rem; font-weight: 600; color: var(--navy); line-height: 1.4; }
    .fc-desc { font-size: 13px; color: var(--grey); line-height: 1.75; flex: 1; letter-spacing: 0.2px; }
    .fc-link { font-size: 13px; font-weight: 600; color: var(--navy); display: flex; align-items: center; gap: 4px; transition: color var(--tr), gap var(--tr); }
    .fc-link:hover { color: var(--red); gap: 8px; }

    /* HOW IT WORKS */
    .hiw { background: linear-gradient(135deg, #1a1f2e 0%, #2b3744 50%, #1f2937 100%); padding: 96px 0; position: relative; overflow: hidden; }
    .hiw::before { content: ''; position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(234,47,61,0.08) 0%, transparent 70%); pointer-events: none; }
    .hiw::after { content: ''; position: absolute; bottom: -80px; left: -80px; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(43,187,115,0.06) 0%, transparent 70%); pointer-events: none; }
    .hiw .eyebrow { color: rgba(255,255,255,0.45); }
    .hiw h2 { color: var(--white); margin-bottom: 52px; }
    .steps-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    @media(max-width:768px){ .steps-grid { grid-template-columns: 1fr; } }
    .step-c { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--r-lg); padding: 32px 26px 36px; transition: background var(--tr), transform var(--tr); }
    .step-c:hover { background: rgba(255,255,255,0.09); transform: translateY(-4px); }
    .step-num { font-size: 3.5rem; font-weight: 700; color: rgba(255,255,255,0.08); line-height: 1; margin-bottom: 16px; }
    .step-img-wrap { width: 100%; height: 180px; border-radius: var(--r-md); overflow: hidden; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.1); }
    .step-img-wrap img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; transition: opacity var(--tr), transform 0.5s ease; }
    .step-c:hover .step-img-wrap img { opacity: 1; transform: scale(1.04); }
    .step-title { font-size: 1rem; font-weight: 600; color: var(--white); margin-bottom: 10px; }
    .step-desc { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.75; }
    .step-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(43,187,115,0.15); border: 1px solid rgba(43,187,115,0.25); color: var(--green); font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 100px; margin-top: 16px; }

    /* ABOUT */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
    @media(max-width:900px){ .about-grid { grid-template-columns: 1fr; gap: 40px; } }
    .img-stack { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 260px 180px; gap: 12px; }
    .img-b { border-radius: var(--r-lg); overflow: hidden; background: var(--bg); border: 1px solid var(--stroke); }
    .img-b img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .img-b:hover img { transform: scale(1.04); }
    .img-b.tall { grid-row: span 2; }
    .about-text { display: flex; flex-direction: column; gap: 18px; }
    .about-quote { padding: 18px 22px; border-left: 3px solid var(--red); background: linear-gradient(90deg, #fdf3f3 0%, #fff5f5 100%); border-radius: 0 var(--r-sm) var(--r-sm) 0; font-size: 15px; color: var(--navy); font-style: italic; line-height: 1.7; }
    .checks { display: flex; flex-direction: column; gap: 10px; }
    .chk { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: var(--grey); line-height: 1.6; }
    .chk-dot { width: 20px; height: 20px; border-radius: 50%; background: var(--green-pale); display: flex; align-items: center; justify-content: center; color: var(--green); font-size: 10px; font-weight: 700; flex-shrink: 0; margin-top: 2px; }

    /* CASE STUDIES */
    .cases-grid { display: flex; gap: 20px; margin-top: 52px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 20px; }
    .cases-grid::-webkit-scrollbar { height: 6px; }
    .cases-grid::-webkit-scrollbar-track { background: var(--bg); border-radius: 4px; }
    .cases-grid::-webkit-scrollbar-thumb { background: var(--stroke); border-radius: 4px; }
    .case-c { min-width: 380px; scroll-snap-align: start; }
    @media(max-width:768px){ .case-c { min-width: 320px; } }
    .case-c { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
    .case-img { height: 220px; overflow: hidden; background: var(--bg); position: relative; }
    .case-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .case-c:hover .case-img img { transform: scale(1.04); }
    .case-tag { position: absolute; top: 14px; left: 14px; background: var(--white); border-radius: 100px; padding: 4px 12px; font-size: 11px; font-weight: 600; color: var(--navy); box-shadow: var(--sh-sm); }
    .case-result { position: absolute; bottom: 14px; right: 14px; background: var(--green); border-radius: 100px; padding: 4px 12px; font-size: 11px; font-weight: 700; color: var(--white); }
    .case-body { padding: 24px 24px 28px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
    .case-title { font-size: 1rem; font-weight: 600; color: var(--navy); line-height: 1.35; }
    .case-desc { font-size: 13px; color: var(--grey); line-height: 1.75; flex: 1; }

    /* PRODUCT SHOWCASE */
    .prod-g { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
    @media(max-width:900px){ .prod-g { grid-template-columns: 1fr; gap: 40px; } }
    .prod-img { border-radius: var(--r-xl); overflow: hidden; background: var(--bg); border: 1px solid var(--stroke); aspect-ratio: 4/5; position: relative; }
    .prod-img img { width: 100%; height: 100%; object-fit: cover; }
    .prod-badge { position: absolute; bottom: 22px; left: 22px; background: var(--white); border: 1px solid var(--stroke); border-radius: var(--r-md); padding: 16px 20px; box-shadow: var(--sh-md); }
    .pb-l { font-size: 10px; font-weight: 600; color: var(--grey); letter-spacing: 1px; text-transform: uppercase; }
    .pb-v { font-size: 1.5rem; font-weight: 700; color: var(--navy); margin-top: 3px; line-height: 1; }
    .pb-s { font-size: 11px; color: var(--green); font-weight: 600; margin-top: 4px; }
    .prod-t { display: flex; flex-direction: column; gap: 18px; }
    .label { font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--grey); }
    .pfl { display: flex; flex-direction: column; gap: 12px; }
    .pf { display: flex; align-items: flex-start; gap: 14px; padding: 14px 16px; background: var(--bg); border-radius: var(--r-md); border: 1px solid var(--stroke); transition: border-color var(--tr); }
    .pf:hover { border-color: rgba(234,47,61,0.3); }
    .pf-t { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 3px; }
    .pf-d { font-size: 12.5px; color: var(--grey); line-height: 1.6; }
    .btn-blue { background: var(--red); color: var(--white); border: none; }
    .btn-blue:hover { background: var(--red-h); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(234,47,61,0.28); }

    /* TESTIMONIALS */
    .test-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 52px; }
    @media(max-width:900px){ .test-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:600px){ .test-grid { grid-template-columns: 1fr; } }
    .tc { padding: 26px 22px 28px; display: flex; flex-direction: column; gap: 14px; }
    .tstars { color: #f59e0b; font-size: 13px; letter-spacing: 2px; }
    .tbody { font-size: 14px; color: var(--grey); line-height: 1.75; flex: 1; letter-spacing: 0.2px; }
    .tbody strong { color: var(--navy); }
    .tauth { display: flex; align-items: center; gap: 12px; }
    .tav { width: 40px; height: 40px; border-radius: 50%; background: var(--icon-bg); display: flex; align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0; border: 2px solid var(--stroke); overflow: hidden; }
    .tname { font-size: 14px; font-weight: 600; color: var(--navy); }
    .trole { font-size: 12px; color: var(--grey); margin-top: 1px; }
    .tpill { display: inline-flex; align-items: center; gap: 5px; background: var(--green-pale); color: var(--green); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 100px; align-self: flex-start; }

    /* CTA BAND */
    .cta-band { background: linear-gradient(135deg, #ea2f3d 0%, #c41926 50%, #8b0f1a 100%); padding: 96px 0; position: relative; overflow: hidden; }
    .cta-band::before { content:''; position:absolute; top:-200px; right:-200px; width:500px; height:500px; border-radius:50%; background:radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); pointer-events:none; }
    .cta-band::after { content:''; position:absolute; bottom:-150px; left:-150px; width:360px; height:360px; border-radius:50%; background:radial-gradient(circle, rgba(0,0,0,0.15) 0%, transparent 70%); pointer-events:none; }
    .cta-inner { text-align: center; position: relative; z-index: 1; }
    .cta-inner .eyebrow { color: rgba(255,255,255,0.5); }
    .cta-title { font-size: clamp(1.8rem,3.5vw,2.6rem); font-weight: 700; color: var(--white); margin: 14px 0; line-height: 1.25; }
    .cta-sub { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 460px; margin: 0 auto 36px; line-height: 1.75; }
    .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-w { background: var(--white); color: var(--red); font-family: 'Poppins',sans-serif; font-size: 14px; font-weight: 700; padding: 13px 28px; border-radius: var(--r-sm); border: none; cursor: pointer; transition: background var(--tr), transform var(--tr); display: inline-flex; align-items: center; }
    .btn-cta-w:hover { background: var(--bg); transform: translateY(-1px); }
    .btn-cta-outline { border: 1.5px solid rgba(255,255,255,0.4); color: var(--white); font-family: 'Poppins',sans-serif; font-size: 14px; font-weight: 600; padding: 13px 28px; border-radius: var(--r-sm); background: none; cursor: pointer; transition: border-color var(--tr), transform var(--tr); display: inline-flex; align-items: center; }
    .btn-cta-outline:hover { border-color: rgba(255,255,255,0.8); transform: translateY(-1px); }
    .cta-note { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 16px; }

    /* FOOTER */
    .footer { padding: 72px 0 32px; border-top: 1px solid var(--stroke); }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 56px; margin-bottom: 56px; }
    @media(max-width:900px){ .footer-top { grid-template-columns: 1fr 1fr; gap: 36px; } }
    @media(max-width:600px){ .footer-top { grid-template-columns: 1fr; } }
    .footer-brand p { font-size: 14px; color: var(--grey); margin-top: 14px; max-width: 250px; line-height: 1.7; }
    .foot-socials { display: flex; gap: 8px; margin-top: 22px; }
    .fsoc { width: 34px; height: 34px; border-radius: var(--r-sm); background: var(--bg); border: 1px solid var(--stroke); display: flex; align-items: center; justify-content: center; font-size: 14px; transition: background var(--tr), transform var(--tr); }
    .fsoc:hover { background: #fde8e9; transform: translateY(-2px); }
    .footer-col h5 { font-size: 11px; font-weight: 700; color: var(--navy); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 16px; }
    .flinks { display: flex; flex-direction: column; gap: 11px; }
    .flinks a { font-size: 14px; color: var(--grey); transition: color var(--tr); }
    .flinks a:hover { color: var(--red); }
    .footer-bottom { border-top: 1px solid var(--stroke); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
    .fcopy { font-size: 13px; color: var(--grey); }
    .flegal { display: flex; gap: 20px; }
    .flegal a { font-size: 13px; color: var(--grey); transition: color var(--tr); }
    .flegal a:hover { color: var(--red); }

    ::-webkit-scrollbar{width:5px} ::-webkit-scrollbar-track{background:var(--bg)} ::-webkit-scrollbar-thumb{background:var(--stroke);border-radius:4px}
  </style>
</head>
